APP_ENV=production
FRONTEND_URL=https://app.example.com
BACKEND_URL=https://api.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1
CORS_ALLOWED_ORIGINS=https://app.example.com
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
REQUEST_ID_HEADER=X-Request-ID
RATE_LIMIT_ENABLED=true

POSTGRES_DB=applymate
POSTGRES_USER=applymate
POSTGRES_PASSWORD=
DATABASE_URL=
REDIS_URL=

JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

AI_PROVIDER=disabled
OPENAI_API_KEY=
OPENAI_MODEL=

CALENDAR_PROVIDER=disabled
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=https://api.example.com/api/v1/integrations/calendar/callback

GMAIL_PROVIDER=disabled
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_GMAIL_REDIRECT_URI=https://api.example.com/api/v1/integrations/gmail/callback

EMAIL_PROVIDER=disabled
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=ApplyMate AI

EXTERNAL_TOKEN_ENCRYPTION_KEY=
EXTERNAL_TOKEN_ENCRYPTION_KEY_VERSION=v1
